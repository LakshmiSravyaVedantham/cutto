# Required
GOOGLE_API_KEY=your-google-ai-studio-api-key

# Models (defaults shown — override if needed)
GEMINI_MODEL=gemini-2.0-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
IMAGEN_MODEL=imagen-4.0-generate-001
VEO_MODEL=veo-2.0-generate-001

# Music directory (relative to backend/)
MUSIC_DIR=./music

# Optional: restrict access with a demo key (?key=xxx in URL)
DEMO_SECRET=

# Optional: Google Cloud Storage bucket for video persistence
GCS_BUCKET=

# Optional: Google Cloud credentials for Cloud TTS (WaveNet voices)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
